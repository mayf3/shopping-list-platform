NODE_ENV=development
PORT=3001
NODE_OPTIONS=--max-old-space-size=384
DATABASE_PATH=./data/shopping-list.db
JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173
DEFAULT_MONTHLY_BUDGET=3000

# Initial users created by the seed script when missing.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
FAMILY_USERNAME=family
FAMILY_PASSWORD=family123

# Frontend dev can leave this blank and use the Vite /api proxy.
VITE_API_BASE_URL=
